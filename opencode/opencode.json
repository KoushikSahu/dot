    "ddg": {
      "type": "local",
      "command": ["uvx", "duckduckgo-mcp-server"]
    }
  },
  "agent": {
    "plan": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high"
    },
    "build": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high"
    }
  }
}
